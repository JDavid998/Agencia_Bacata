<div class="login-container">
  <div class="contact-form-center">
    <div class="contact-form w-full max-w-md">
      <div class="flex flex-col items-center mb-8">
        <div class="w-20 h-20 bg-gradient-to-br from-indigo-500 via-purple-600 to-pink-500 rounded-full flex items-center justify-center mb-6 shadow-xl">
          <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-gray-800 mb-3">Iniciar sesión</h2>
        <p class="text-gray-600 text-center text-lg">Bienvenido de nuevo a Agencia Bacata</p>
      </div>
      
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-6">
          <div>
            <%= f.label :email, class: "block text-sm font-semibold text-indigo-700 mb-2" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                class: "block w-full rounded-xl border border-indigo-200 px-4 py-3 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-white/90 backdrop-blur-sm sm:text-sm transition-all duration-200 shadow-sm hover:shadow-md" %>
          </div>
          
          <div>
            <%= f.label :password, class: "block text-sm font-semibold text-indigo-700 mb-2" %>
            <%= f.password_field :password, autocomplete: "current-password", 
                class: "block w-full rounded-xl border border-indigo-200 px-4 py-3 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 bg-white/90 backdrop-blur-sm sm:text-sm transition-all duration-200 shadow-sm hover:shadow-md" %>
          </div>
          
          <% if devise_mapping.rememberable? %>
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <%= f.check_box :remember_me, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-indigo-300 rounded" %>
                <%= f.label :remember_me, class: "ml-2 block text-sm text-gray-700" %>
              </div>
              <%= link_to "¿Olvidaste tu contraseña?", new_password_path(resource_name), 
                  class: "text-sm text-indigo-600 hover:text-indigo-800 transition-colors hover:underline" %>
            </div>
          <% end %>
          
          <div class="pt-3">
            <%= f.submit "Iniciar sesión", 
                class: "login-submit-btn w-full px-6 py-3 rounded-xl font-bold shadow-lg tracking-wide text-lg border-0" %>
          </div>
        </div>
      <% end %>
      
      <div class="mt-8 pt-6 border-t border-gray-200">
        <div class="text-center">
          <p class="text-gray-600 mb-4">¿No tienes una cuenta?</p>
          <%= link_to "Regístrate aquí", new_registration_path(resource_name), 
              class: "inline-block px-6 py-2 border-2 border-indigo-600 text-indigo-600 rounded-lg hover:bg-indigo-600 hover:text-white transition-all duration-200 font-medium hover:shadow-md" %>
        </div>
      </div>
    </div>
  </div>
</div>

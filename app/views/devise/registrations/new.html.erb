
<div class="contact-form-center">
  <div class="contact-form w-full max-w-md">
    <div class="flex flex-col items-center mb-6">
      <svg class="w-16 h-16 text-indigo-600 mb-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" fill="currentColor"/><rect x="6" y="16" width="12" height="4" rx="2" fill="currentColor"/></svg>
      <h2 class="text-2xl font-bold text-gray-800 mt-2">Crear cuenta</h2>
      <p class="text-sm text-gray-500 mt-1">Regístrate para acceder a la plataforma</p>
    </div>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <div class="space-y-4">
        <div>
          <%= f.label :email, class: "block text-sm font-semibold text-indigo-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "block w-full rounded-xl border border-indigo-200 px-4 py-2 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-indigo-400 bg-indigo-50/50 sm:text-sm transition shadow-sm" %>
        </div>
        <div>
          <%= f.label :password, class: "block text-sm font-semibold text-indigo-700 mb-1" %>
          <% if @minimum_password_length %>
            <em class="text-xs text-gray-400">(<%= @minimum_password_length %> caracteres mínimo)</em>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "block w-full rounded-xl border border-indigo-200 px-4 py-2 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-indigo-400 bg-indigo-50/50 sm:text-sm transition shadow-sm mt-1" %>
        </div>
        <div>
          <%= f.label :password_confirmation, class: "block text-sm font-semibold text-indigo-700 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "block w-full rounded-xl border border-indigo-200 px-4 py-2 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:border-indigo-400 bg-indigo-50/50 sm:text-sm transition shadow-sm" %>
        </div>
        <div>
          <%= f.submit "Registrarme", class: "w-full bg-gradient-to-r from-indigo-500 via-fuchsia-500 to-pink-500 text-white px-6 py-2 rounded-xl hover:from-indigo-600 hover:to-pink-600 transition font-bold shadow-lg tracking-wide text-lg" %>
        </div>
      </div>
    <% end %>
    <div class="mt-6 flex flex-col items-center space-y-2">   
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>

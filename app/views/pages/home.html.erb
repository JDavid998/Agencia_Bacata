
<main>
    <!-- Swiper Carrusel -->
    <div class="swiper w-full max-w-4xl mx-auto mt-8 rounded-2xl overflow-hidden shadow-2xl min-h-[350px] h-[40vw] max-h-[500px] flex items-center bg-white/80">
        <div class="swiper-wrapper">
            <div class="swiper-slide flex items-center justify-center">
                <%= image_tag 'slide1.jpg', alt: 'Slide 1', class: 'w-full h-[40vw] max-h-[500px] min-h-[350px] object-cover object-center' %>
            </div>
            <div class="swiper-slide flex items-center justify-center">
                <%= image_tag 'slide2.jpg', alt: 'Slide 2', class: 'w-full h-[40vw] max-h-[500px] min-h-[350px] object-cover object-center' %>
            </div>
        </div>
        <!-- Pagination and navigation -->
        <div class="swiper-pagination"></div>
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
    </div>

    <section class="max-w-2xl mx-auto bg-white/90 rounded-xl shadow-lg p-8 mt-10 text-center">
        <h1 class="text-3xl font-bold text-indigo-700 mb-4">Bienvenido a Agencia Bacata</h1>
        <p class="mb-6 text-gray-700">La buena mis papachos!</p>
    </section>
</main>
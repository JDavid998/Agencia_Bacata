<% content_for :page_title, @page_title %>
<% content_for :page_subtitle, @page_subtitle %>

<div class="dashboard-content">
  <!-- Header de bienvenida -->
  <div class="welcome-section">
    <div class="welcome-content">
      <h1 class="welcome-title">¡Hola, <%= current_user.email.split('@').first.capitalize %>! 👋</h1>
      <p class="welcome-subtitle">Aquí tienes un resumen completo de tus campañas de marketing digital</p>
    </div>
    <div class="welcome-actions">
      <button class="dashboard-btn">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        Nueva Campaña
      </button>
    </div>
  </div>

  <!-- Métricas principales en grid moderno -->
  <div class="metrics-grid">
    <div class="metric-card">
      <div class="metric-header">
        <div class="metric-icon bg-blue-100">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
          </svg>
        </div>
        <div class="metric-info">
          <span class="metric-label">Total Impresiones</span>
          <div class="metric-value"><%= number_with_delimiter(@totals[:impresiones]) %></div>
        </div>
      </div>
    </div>

    <div class="metric-card">
      <div class="metric-header">
        <div class="metric-icon bg-green-100">
          <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <div class="metric-info">
          <span class="metric-label">Total Clics</span>
          <div class="metric-value"><%= number_with_delimiter(@totals[:clics]) %></div>
        </div>
      </div>
    </div>

    <div class="metric-card">
      <div class="metric-header">
        <div class="metric-icon bg-purple-100">
          <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
          </svg>
        </div>
        <div class="metric-info">
          <span class="metric-label">Gasto Total</span>
          <div class="metric-value">$<%= number_with_precision(@totals[:gasto], precision: 0) %></div>
        </div>
      </div>
    </div>

    <div class="metric-card">
      <div class="metric-header">
        <div class="metric-icon bg-orange-100">
          <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
        </div>
        <div class="metric-info">
          <span class="metric-label">CTR Promedio</span>
          <div class="metric-value"><%= @totals[:ctr_promedio] %>%</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Dashboard en mosaico - 2 columnas principales -->
  <div class="dashboard-mosaic">
    <!-- Columna izquierda -->
    <div class="mosaic-column">
      <!-- Rendimiento por plataforma -->
      <div class="chart-container">
        <h3>Rendimiento por Plataforma</h3>
        <div class="platform-stats">
          <% @stats.each do |plataforma, datos| %>
            <div class="platform-item">
              <div class="platform-header">
                <div class="platform-icon">
                  <span><%= plataforma.to_s.first.upcase %></span>
                </div>
                <div class="platform-details">
                  <h4 class="platform-name"><%= plataforma.to_s.humanize %></h4>
                  <p class="platform-metric"><%= number_with_delimiter(datos[:impresiones]) %> impresiones</p>
                </div>
              </div>
              <div class="platform-stats-right">
                <div class="stat-item">
                  <span class="stat-value"><%= datos[:ctr] %>%</span>
                  <span class="stat-label">CTR</span>
                </div>
                <div class="stat-item">
                  <span class="stat-value">$<%= number_with_precision(datos[:gasto], precision: 0) %></span>
                  <span class="stat-label">Gasto</span>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Acciones rápidas -->
      <div class="chart-container">
        <h3>Acciones Rápidas</h3>
        <div class="quick-actions">
          <button class="dashboard-btn">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
            Ver Reportes
          </button>
          
          <button class="dashboard-btn secondary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            Editar Perfil
          </button>
        </div>
      </div>
    </div>

    <!-- Columna derecha -->
    <div class="mosaic-column">
      <!-- Resumen de gasto -->
      <div class="chart-container">
        <h3>Resumen de Gasto por Plataforma</h3>
        <div class="expense-summary">
          <% @stats.each do |plataforma, datos| %>
            <div class="expense-item">
              <div class="expense-info">
                <div class="expense-icon">
                  <span><%= plataforma.to_s.first.upcase %></span>
                </div>
                <div class="expense-details">
                  <h4 class="expense-name"><%= plataforma.to_s.humanize %></h4>
                  <p class="expense-metric"><%= number_with_delimiter(datos[:clics]) %> clics</p>
                </div>
              </div>
              <div class="expense-amount">
                <span class="amount-value">$<%= number_with_precision(datos[:gasto], precision: 0) %></span>
                <span class="amount-change <%= datos[:cambio].start_with?('+') ? 'positive' : 'negative' %>">
                  <%= datos[:cambio] %>
                </span>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Estadísticas adicionales -->
      <div class="chart-container">
        <h3>Estadísticas Adicionales</h3>
        <div class="additional-stats">
          <div class="stat-card">
            <div class="stat-icon bg-indigo-100">
              <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
            </div>
            <div class="stat-content">
              <span class="stat-title">Rendimiento</span>
              <span class="stat-value">Excelente</span>
            </div>
          </div>
          
          <div class="stat-card">
            <div class="stat-icon bg-emerald-100">
              <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="stat-content">
              <span class="stat-title">Estado</span>
              <span class="stat-value">Activo</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
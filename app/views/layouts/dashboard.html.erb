<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Dashboard - Agencia Bacata" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "custom_background", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "swiper_custom", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "dashboard_styles", "data-turbo-track": "reload" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/swiper@10/swiper-bundle.min.js"></script>
    <%= javascript_include_tag 'packs/swiper_init', 'data-turbo-track': 'reload', defer: true %>

    <!-- Chartkick para gráficos -->
    <%= javascript_include_tag "chartkick" %>
  </head>

  <body class="bg-slate-50">
    <div class="min-h-screen flex">
      <!-- Sidebar moderno y compacto -->
      <aside class="modern-sidebar">
        <div class="sidebar-header">
          <div class="brand">
            <div class="brand-icon">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="8" cy="10" r="4" fill="currentColor"/>
                <circle cx="16" cy="10" r="4" fill="currentColor"/>
                <circle cx="12" cy="17" r="2" fill="currentColor"/>
              </svg>
            </div>
            <span class="brand-text">Bacata</span>
          </div>
        </div>

        <nav class="sidebar-nav">
          <a href="<%= dashboard_path %>" class="nav-item <%= 'active' if controller_name == 'dashboards' %>">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5a2 2 0 012-2h4a2 2 0 012 2v6H8V5z"></path>
            </svg>
            <span>Dashboard</span>
          </a>

          <a href="#" class="nav-item">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
            <span>Campañas</span>
          </a>

          <a href="#" class="nav-item">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
            </svg>
            <span>Reportes</span>
          </a>

          <a href="#" class="nav-item">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            <span>Perfil</span>
          </a>

          <a href="#" class="nav-item">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span>Config</span>
          </a>
        </nav>

        <div class="sidebar-footer">
          <a href="<%= root_path %>" class="nav-item text-slate-400 hover:text-slate-600">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
            </svg>
            <span>Inicio</span>
          </a>
        </div>
      </aside>

      <!-- Contenido principal -->
      <main class="flex-1 flex flex-col">
        <!-- Header superior moderno -->
        <header class="modern-header">
          <div class="header-content">
            <div class="header-left">
              <h1 class="page-title"><%= content_for(:page_title) || "Dashboard" %></h1>
              <p class="page-subtitle"><%= content_for(:page_subtitle) || "Bienvenido de vuelta" %></p>
            </div>

            <div class="header-right">
              <!-- Notificaciones -->
              <button class="header-btn">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-5 5v-5z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M9 11h.01M9 8h.01M15 14h.01M15 11h.01M15 8h.01M15 5h.01M12 5h.01M12 8h.01M12 11h.01M12 14h.01M12 17h.01"></path>
                </svg>
              </button>

              <!-- Perfil del usuario -->
              <div class="user-profile">
                <div class="user-avatar">
                  <span><%= current_user.email.first.upcase %></span>
                </div>
                <div class="user-info">
                  <p class="user-name"><%= current_user.email.split('@').first.capitalize %></p>
                  <p class="user-email"><%= current_user.email %></p>
                </div>
                <%= button_to destroy_user_session_path, method: :delete, 
                    class: "logout-btn", title: "Cerrar sesión" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                  </svg>
                <% end %>
              </div>
            </div>
          </div>
        </header>

        <!-- Contenido principal con scroll -->
        <div class="main-content">
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html> 